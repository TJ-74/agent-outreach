# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Microsoft Outlook (optional)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback
OUTLOOK_SCOPES=openid profile email User.Read Mail.Send Mail.Read offline_access

# Google Gmail (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_SCOPES=openid https://www.googleapis.com/auth/userinfo.profile https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/gmail.send

# Optional
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_AGENT_URL=http://localhost:8000
